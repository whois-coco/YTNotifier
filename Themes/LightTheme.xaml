<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- フラットライトテーマ: シャドウなし・グラデーションなし -->
    <Color x:Key="BackgroundColor">#F5F5F5</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#FAFAFA</Color>
    <Color x:Key="SurfaceElevatedColor">#FFFFFF</Color>
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryLightColor">#EFF6FF</Color>
    <Color x:Key="PrimaryDarkColor">#1D4ED8</Color>
    <Color x:Key="AccentColor">#EF4444</Color>
    <Color x:Key="AccentLightColor">#FEF2F2</Color>
    <Color x:Key="TextPrimaryColor">#111827</Color>
    <Color x:Key="TextSecondaryColor">#374151</Color>
    <Color x:Key="TextMutedColor">#9CA3AF</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="BorderLightColor">#F3F4F6</Color>
    <Color x:Key="HoverColor">#EFF6FF</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="TabActiveColor">#FFFFFF</Color>
    <Color x:Key="TabInactiveColor">#F5F5F5</Color>
    <Color x:Key="LogBackgroundColor">#FAFAFA</Color>
    <Color x:Key="LogTextColor">#374151</Color>
    <Color x:Key="SidebarColor">#FFFFFF</Color>
    <Color x:Key="SidebarTextColor">#374151</Color>
    <Color x:Key="SidebarActiveColor">#2563EB</Color>
    <Color x:Key="SidebarHoverColor">#E5E7EB</Color>
    <Color x:Key="SidebarBorderColor">#E5E7EB</Color>
    <Color x:Key="SidebarSectionColor">#9CA3AF</Color>
    <Color x:Key="SidebarVersionColor">#9CA3AF</Color>
    <Color x:Key="SidebarStatusBgColor">#F3F4F6</Color>
    <Color x:Key="SidebarActiveTextColor">#111827</Color>
    <Color x:Key="SidebarTitleColor">#111827</Color>

    <SolidColorBrush x:Key="BackgroundBrush"      Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"      Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush"    Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush"     Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush"     Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush"     Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="HoverBrush"           Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"         Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush"           Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="TabActiveBrush"       Color="{StaticResource TabActiveColor}"/>
    <SolidColorBrush x:Key="TabInactiveBrush"     Color="{StaticResource TabInactiveColor}"/>
    <SolidColorBrush x:Key="LogBackgroundBrush"   Color="{StaticResource LogBackgroundColor}"/>
    <SolidColorBrush x:Key="LogTextBrush"         Color="{StaticResource LogTextColor}"/>
    <SolidColorBrush x:Key="SidebarBrush"           Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush"       Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush"     Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"      Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarBorderBrush"     Color="{StaticResource SidebarBorderColor}"/>
    <SolidColorBrush x:Key="SidebarSectionBrush"    Color="{StaticResource SidebarSectionColor}"/>
    <SolidColorBrush x:Key="SidebarVersionBrush"    Color="{StaticResource SidebarVersionColor}"/>
    <SolidColorBrush x:Key="SidebarStatusBgBrush"   Color="{StaticResource SidebarStatusBgColor}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="{StaticResource SidebarActiveTextColor}"/>
    <SolidColorBrush x:Key="SidebarTitleBrush"      Color="{StaticResource SidebarTitleColor}"/>

    <!-- 種別トグル -->
    <SolidColorBrush x:Key="ShortBrush"        Color="#F97316"/>

    <!-- ウィンドウ閉じるボタンホバー -->
    <SolidColorBrush x:Key="CloseHoverBrush"   Color="#C42B1C"/>

    <!-- クォータバー -->
    <SolidColorBrush x:Key="QuotaWarnHighBrush" Color="#EAB308"/>
    <SolidColorBrush x:Key="QuotaWarnLowBrush"  Color="#FFD700"/>
    <SolidColorBrush x:Key="QuotaOkBrush"       Color="#22C55E"/>

</ResourceDictionary>
