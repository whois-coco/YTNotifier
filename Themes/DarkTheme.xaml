<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- フラットダークテーマ -->
    <Color x:Key="BackgroundColor">#0F172A</Color>
    <Color x:Key="SurfaceColor">#1E293B</Color>
    <Color x:Key="SurfaceAltColor">#1E293B</Color>
    <Color x:Key="SurfaceElevatedColor">#334155</Color>
    <Color x:Key="PrimaryColor">#3B82F6</Color>
    <Color x:Key="PrimaryLightColor">#1E3A5F</Color>
    <Color x:Key="PrimaryDarkColor">#2563EB</Color>
    <Color x:Key="AccentColor">#EF4444</Color>
    <Color x:Key="AccentLightColor">#450A0A</Color>
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="TextMutedColor">#475569</Color>
    <Color x:Key="BorderColor">#334155</Color>
    <Color x:Key="BorderLightColor">#1E293B</Color>
    <Color x:Key="HoverColor">#1E3A5F</Color>
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#EF4444</Color>
    <Color x:Key="TabActiveColor">#1E293B</Color>
    <Color x:Key="TabInactiveColor">#0F172A</Color>
    <Color x:Key="LogBackgroundColor">#0F172A</Color>
    <Color x:Key="LogTextColor">#64748B</Color>
    <Color x:Key="SidebarColor">#0F172A</Color>
    <Color x:Key="SidebarTextColor">#94A3B8</Color>
    <Color x:Key="SidebarActiveColor">#3B82F6</Color>
    <Color x:Key="SidebarHoverColor">#1E293B</Color>
    <Color x:Key="SidebarBorderColor">#1E293B</Color>
    <Color x:Key="SidebarSectionColor">#475569</Color>
    <Color x:Key="SidebarVersionColor">#475569</Color>
    <Color x:Key="SidebarStatusBgColor">#1E293B</Color>
    <Color x:Key="SidebarActiveTextColor">#FFFFFF</Color>
    <Color x:Key="SidebarTitleColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="BackgroundBrush"      Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush"      Color="{StaticResource SurfaceAltColor}"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevatedColor}"/>
    <SolidColorBrush x:Key="PrimaryBrush"         Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush"    Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush"     Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush"     Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"       Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush"     Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="HoverBrush"           Color="{StaticResource HoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"         Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"         Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush"           Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="TabActiveBrush"       Color="{StaticResource TabActiveColor}"/>
    <SolidColorBrush x:Key="TabInactiveBrush"     Color="{StaticResource TabInactiveColor}"/>
    <SolidColorBrush x:Key="LogBackgroundBrush"   Color="{StaticResource LogBackgroundColor}"/>
    <SolidColorBrush x:Key="LogTextBrush"         Color="{StaticResource LogTextColor}"/>
    <SolidColorBrush x:Key="SidebarBrush"           Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush"       Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush"     Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"      Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarBorderBrush"     Color="{StaticResource SidebarBorderColor}"/>
    <SolidColorBrush x:Key="SidebarSectionBrush"    Color="{StaticResource SidebarSectionColor}"/>
    <SolidColorBrush x:Key="SidebarVersionBrush"    Color="{StaticResource SidebarVersionColor}"/>
    <SolidColorBrush x:Key="SidebarStatusBgBrush"   Color="{StaticResource SidebarStatusBgColor}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="{StaticResource SidebarActiveTextColor}"/>
    <SolidColorBrush x:Key="SidebarTitleBrush"      Color="{StaticResource SidebarTitleColor}"/>



</ResourceDictionary>
