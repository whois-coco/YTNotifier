<Window x:Class="YTNotifier.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="YTNotifier" Height="740" Width="980"
        MinHeight="460" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- サイドバーナビボタン -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="Padding"                Value="0"/>
            <Setter Property="Height"                 Value="40"/>
            <Setter Property="HorizontalAlignment"    Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="NavIcon"
                                           Grid.Column="0"
                                           Text="{Binding Tag,
                                               RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SidebarTextBrush}"/>
                                <TextBlock x:Name="NavLabel"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           FontSize="13"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SidebarTextBrush}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SidebarHoverBrush}"/>
                                <Setter TargetName="NavIcon" Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="NavLabel" Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Content" Value="">
                                <Setter TargetName="NavLabel" Property="Visibility"
                                        Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アクティブナビ: 左に青ライン -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border Background="{DynamicResource SidebarHoverBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="NavIcon"
                                               Grid.Column="0"
                                               Text="{Binding Tag,
                                                   RelativeSource={RelativeSource TemplatedParent}}"
                                               FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SidebarActiveTextBrush}"/>
                                    <TextBlock x:Name="NavLabel"
                                               Grid.Column="1"
                                               Text="{TemplateBinding Content}"
                                               FontSize="13"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SidebarActiveTextBrush}"/>
                                </Grid>
                            </Border>
                            <Border Width="3" HorizontalAlignment="Left"
                                    Background="{DynamicResource SidebarActiveBrush}"
                                    CornerRadius="0,2,2,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="">
                                <Setter TargetName="NavLabel" Property="Visibility"
                                        Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ウィンドウ外枠（フラット枠線） -->
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== カスタムタイトルバー ===== -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- アプリ名（サイドバー幅に追従・クリップ） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0"
                            ClipToBounds="True">
                    <Border Width="20" Height="20" CornerRadius="3"
                            Background="{DynamicResource AccentBrush}"
                            Margin="0,0,8,0">
                        <TextBlock Text="▶" Foreground="White" FontSize="9"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TitleText" Text="YTNotifier" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource SidebarTitleBrush}"
                               VerticalAlignment="Center"
                               Visibility="Visible"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- ドラッグ領域 -->
                <Border Grid.Column="1"/>

                <!-- ウィンドウ操作ボタン -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 最小化 -->
                    <Button Click="TitleBar_Minimize"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="最小化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock Text="─" Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 最大化/復元 -->
                    <Button x:Name="MaximizeButton" Click="TitleBar_Maximize"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="最大化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock x:Name="MaxIcon" Text="□"
                                               Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 閉じる -->
                    <Button Click="TitleBar_Close"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="閉じる">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock Text="✕" Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="#EF4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== メインレイアウト（タイトルバー下） ===== -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="140" MinWidth="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== サイドバー ===== -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}"
                ClipToBounds="True">
            <DockPanel>

                <!-- ステータス＋折り畳みボタン -->
                <Border DockPanel.Dock="Top"
                        Height="48"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <!-- ステータスバッジ（クリックで監視トグル） -->
                        <Button x:Name="StatusBadge"
                                Grid.Column="0"
                                Background="{DynamicResource SidebarStatusBgBrush}"
                                BorderThickness="0"
                                Padding="8,5"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Cursor="Hand"
                                ToolTip="クリックして監視を開始/停止"
                                Click="MonitorToggleButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="3"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Margin="0,0,6,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush x:Name="StatusDot" Color="#94A3B8"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock x:Name="StatusText" Text="停止中"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SidebarTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- 折り畳みボタン: 常に右端44px列の中央 -->
                        <Button x:Name="SidebarToggleButton"
                                Grid.Column="1"
                                Click="SidebarToggle_Click"
                                Width="44" Height="48"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="メニューを折り畳む">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent">
                                        <TextBlock x:Name="ToggleIcon" Text="◀"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SidebarTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource SidebarHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- ピンボタン（サイドバー左下） -->
                <Border DockPanel.Dock="Bottom"
                        Height="44"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Button x:Name="PinButton"
                            Width="44" Height="44"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Left"
                            Click="PinButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="44" Height="44">
                                    <TextBlock x:Name="PinIcon" Text="⚲"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>

                <!-- ナビゲーション -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <Border x:Name="MenuLabelWrap" Visibility="Visible">
                        <TextBlock x:Name="MenuLabel" Text="MENU" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource SidebarSectionBrush}"
                                   Margin="16,0,0,6"/>
                    </Border>
                    <Button x:Name="NavWatch" Tag="📋" Content="チャンネルリスト"
                            Style="{StaticResource NavButtonActive}"
                            Click="Nav_Click"/>

                    <Button x:Name="NavLog" Tag="📝" Content="動作ログ"
                            Style="{StaticResource NavButton}"
                            Click="Nav_Click"/>
                    <Button x:Name="NavSettings" Tag="⚙" Content="基本設定"
                            Style="{StaticResource NavButton}"
                            Click="Nav_Click"/>
                </StackPanel>

                <!-- 区切りと ActionsLabel は不要になったが折り畳み制御のため残す -->
                <Border DockPanel.Dock="Top" Height="0"/>
                <StackPanel DockPanel.Dock="Top">
                    <Border x:Name="ActionsLabelWrap" Visibility="Collapsed">
                        <TextBlock x:Name="ActionsLabel" Text="" FontSize="9"/>
                    </Border>
                </StackPanel>



            </DockPanel>
        </Border>


        <!-- ===== メインコンテンツ ===== -->
        <Grid Grid.Column="1" Background="{DynamicResource BackgroundBrush}">

            <!-- チャンネルリスト -->
            <DockPanel x:Name="PageWatch" Margin="24,20">

                <!-- ページヘッダー -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="チャンネルリスト" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="ChannelCountText" Text="0 チャンネル"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button x:Name="InlineCheckButton"
                                Grid.Column="1"
                                Content="🔄"
                                FontSize="15"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                ToolTip="今すぐチェック"
                                Click="ManualCheckButton_Click"/>
                        <Button x:Name="EditModeButton"
                                Grid.Column="2"
                                Content="✏"
                                FontSize="15"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6"
                                VerticalAlignment="Center"
                                ToolTip="編集"
                                Click="EditModeButton_Click"/>
                    </Grid>
                </Border>

                <!-- チャンネル追加ボタン -->
                <Button DockPanel.Dock="Bottom"
                        Style="{StaticResource SecondaryButton}"
                        Content="＋ チャンネルを追加"
                        Padding="16,10"
                        Margin="0,8,0,0"
                        FontSize="13"
                        Click="AddChannelHeader_Click"/>

                <!-- チャンネルリスト -->
                <Grid>
                    <Border x:Name="EmptyState" Visibility="Collapsed" Panel.ZIndex="1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="0,40,0,0">
                            <TextBlock Text="📭" FontSize="40"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="監視チャンネルがありません"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="下のフォームからチャンネルを追加してください"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="ChannelScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalContentAlignment="Stretch">
                        <ScrollViewer.Template>
                            <ControlTemplate TargetType="ScrollViewer">
                                <Grid HorizontalAlignment="Stretch">
                                    <ScrollContentPresenter
                                        HorizontalAlignment="Stretch"
                                        CanContentScroll="False"/>
                                    <ScrollBar x:Name="PART_VerticalScrollBar"
                                               HorizontalAlignment="Right"
                                               Width="4"
                                               Value="{TemplateBinding VerticalOffset}"
                                               Maximum="{TemplateBinding ScrollableHeight}"
                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                               Style="{StaticResource SlimScrollBar}"/>
                                </Grid>
                            </ControlTemplate>
                        </ScrollViewer.Template>
                        <StackPanel x:Name="ChannelList" HorizontalAlignment="Stretch"/>
                    </ScrollViewer>
                </Grid>
            </DockPanel>

            <!-- 動作ログ -->
            <Grid x:Name="PageLog" Visibility="Collapsed" Margin="24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- ヘッダー Row=0 -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="動作ログ" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="リアルタイム監視ログ" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button Style="{StaticResource SecondaryButton}"
                                    Click="ClearLog_Click" Padding="10,7"
                                    Content="🗑 クリア"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 動作ログ本体 Row=1 -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <Border Background="{DynamicResource LogBackgroundBrush}" CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                            <ItemsControl x:Name="LogList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="2"
                                                    Padding="5,1" Margin="0,0,6,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding LevelColor, Mode=OneWay}"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding LevelText, Mode=OneWay}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock FontFamily="Cascadia Code, Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           Text="{Binding ChannelNameFormatted, Mode=OneWay}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock FontFamily="Cascadia Code, Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource LogTextBrush}"
                                                           Text="{Binding Message, Mode=OneWay}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Border>

            </Grid><!-- PageLog -->

            <!-- 基本設定 -->
            <Grid x:Name="PageSettings" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ページタイトル -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,20,24,16">
                    <TextBlock Text="基本設定" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>

                <!-- サブナビゲーション（横向き） -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Height="36">
                        <Border x:Name="SettingsNavApp"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryBrush}"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="アプリ" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SettingsNavMonitor"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="監視" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SettingsNavLog"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="ログ" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SettingsNavApi"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="API" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SettingsNavAbout"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="ABOUT" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- コンテンツエリア -->
                <Grid Grid.Row="2">

                    <!-- API -->
                    <ScrollViewer x:Name="SettingsPageApi" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <TextBlock Text="APIキー" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ApiKeyBox" Grid.Column="0"
                                         Style="{StaticResource ModernTextBox}"
                                         IsReadOnly="True" TextAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <Button x:Name="SaveApiKeyButton" Grid.Column="1"
                                        Style="{StaticResource PrimaryButton}"
                                        Content="保存" Padding="12,8"
                                        Click="SaveApiKey_Click"/>
                            </Grid>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}">
                                <Hyperlink RequestNavigate="ApiKeyLink_Click"
                                           NavigateUri="https://console.developers.google.com">
                                    Google Cloud Console でAPIキーを取得 →
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 監視 -->
                    <ScrollViewer x:Name="SettingsPageMonitor" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="チェック間隔" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="IntervalComboBox" Grid.Column="1"
                                          Style="{StaticResource ModernComboBox}"
                                          SelectionChanged="IntervalComboBox_SelectionChanged">
                                    <ComboBoxItem Content="3分"  Tag="3"  Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="5分"  Tag="5"  Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="10分" Tag="10" Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="15分" Tag="15" Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="20分" Tag="20" Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="30分" Tag="30" Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="60分" Tag="60" Style="{StaticResource ModernComboBoxItem}"/>
                                </ComboBox>
                            </Grid>
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="10,8" Margin="0,0,0,12">
                                <TextBlock x:Name="QuotaInfoText" FontSize="12"
                                           Text="推定消費量: 計算中..."
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                            </Border>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="デスクトップ通知" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="NotificationToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="NotificationToggle_Changed"
                                          Unchecked="NotificationToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="通知音" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="NotificationSoundToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="NotificationSoundToggle_Changed"
                                          Unchecked="NotificationSoundToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="通知テスト" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Content="🔔 送信" Padding="14,7"
                                        VerticalAlignment="Center"
                                        Click="TestNotification_Click"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- アプリ -->
                    <ScrollViewer x:Name="SettingsPageApp"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ダークモード" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="DarkModeToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="DarkModeToggle_Changed"
                                          Unchecked="DarkModeToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="コンパクトモード" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="CompactModeToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="CompactModeToggle_Changed"
                                          Unchecked="CompactModeToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="タスクトレイに格納" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="TrayToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="TrayToggle_Changed"
                                          Unchecked="TrayToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="スタートアップ起動" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="StartupToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="StartupToggle_Changed"
                                          Unchecked="StartupToggle_Changed"/>
                            </Grid>
                            <CheckBox x:Name="AlwaysOnTopToggle" Visibility="Collapsed"
                                      Checked="AlwaysOnTopToggle_Changed"
                                      Unchecked="AlwaysOnTopToggle_Changed"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ログ -->
                    <ScrollViewer x:Name="SettingsPageLog" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="12,10" Margin="0,0,0,12">
                                <TextBlock x:Name="LogStatsText"
                                           Text="ログ情報を読み込み中..."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="自動ログ削除" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="AutoCleanLogsToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="AutoCleanLogsToggle_Changed"
                                          Unchecked="AutoCleanLogsToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ログ保持期間" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="LogRetentionComboBox" Grid.Column="1"
                                          Style="{StaticResource ModernComboBox}"
                                          SelectionChanged="LogRetentionComboBox_Changed">
                                    <ComboBoxItem Content="0日（当日のみ）" Tag="0"  Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="1日"  Tag="1"   Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="3日"  Tag="3"   Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="5日"  Tag="5"   Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="7日"  Tag="7"   Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="無制限" Tag="-1" Style="{StaticResource ModernComboBoxItem}"/>
                                </ComboBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="LogCleanResultText" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center" Text=""/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Content="🗑 削除実行" Padding="14,7"
                                        Margin="0,0,8,0" VerticalAlignment="Center"
                                        Click="CleanLogsNow_Click"/>
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                        Content="📁 フォルダを開く" Padding="14,7"
                                        VerticalAlignment="Center"
                                        Click="OpenLogFolder_Click"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ABOUT -->
                    <ScrollViewer x:Name="SettingsPageAbout" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <TextBlock Text="YTNotifier" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="v1.7.1" FontSize="13"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,0,12"/>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <TextBlock Text="YouTube新着動画通知アプリ" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="YouTube Data API v3 使用" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <TextBlock Text="Created by Coco" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Grid>

        </Grid>
        </Grid><!-- メインレイアウト -->

    </Grid><!-- ルートGrid -->
    </Border><!-- ウィンドウ外枠 -->
</Window>
