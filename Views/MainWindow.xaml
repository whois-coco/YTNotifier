                                                          Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="サムネイル通知" Tag="Thumbnail"
                                                          Style="{StaticResource ModernComboBoxItem}"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <!-- 通知テスト（グループ外） -->
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="通知テスト" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Content="🔔 送信" Padding="14,7"
                                        VerticalAlignment="Center"
                                        Click="TestNotification_Click"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- アプリ -->
                    <ScrollViewer x:Name="SettingsPageApp" Style="{StaticResource SlimScrollViewer}" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <!-- APIキー -->
                            <TextBlock Text="APIキー" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ApiKeyBox" Grid.Column="0"
                                         Style="{StaticResource ModernTextBox}"
                                         IsReadOnly="True" TextAlignment="Center"
                                         FontSize="11"
                                         Padding="8,4"
                                         Margin="0,0,8,0"
                                         Background="{DynamicResource SurfaceAltBrush}"
                                         Foreground="{DynamicResource TextMutedBrush}"/>
                                <Button x:Name="SaveApiKeyButton" Grid.Column="1"
                                        Style="{StaticResource PrimaryButton}"
                                        Content="保存" Padding="12,5"
                                        FontSize="11"
                                        Click="SaveApiKey_Click"/>
                            </Grid>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,0">
                                <Hyperlink RequestNavigate="ApiKeyLink_Click"
                                           NavigateUri="https://console.developers.google.com">
                                    Google Cloud Console でAPIキーを取得 →
                                </Hyperlink>
                            </TextBlock>
                            <Separator Style="{StaticResource HorizontalSeparator}" Margin="0,12,0,8"/>
                            <!-- CompactModeToggle は非表示（サイドバーボタンで制御） -->
                            <CheckBox x:Name="CompactModeToggle" Visibility="Collapsed"
                                      Checked="CompactModeToggle_Changed"
                                      Unchecked="CompactModeToggle_Changed"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="タスクトレイに格納" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="TrayToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="TrayToggle_Changed"
                                          Unchecked="TrayToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="スタートアップ起動" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <CheckBox x:Name="StartupToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="StartupToggle_Changed"
                                          Unchecked="StartupToggle_Changed"/>
                            </Grid>
                            <CheckBox x:Name="AlwaysOnTopToggle" Visibility="Collapsed"
                                      Checked="AlwaysOnTopToggle_Changed"
                                      Unchecked="AlwaysOnTopToggle_Changed"/>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <!-- バックアップ / インポート -->
                            <TextBlock Text="バックアップ" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="設定ファイルを書き出す" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Content="💾 バックアップ" Padding="12,6" Width="110"
                                        Click="ExportBackup_Click"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="バックアップから復元する" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Content="📂 復元" Padding="12,6" Width="110"
                                        Click="ImportBackup_Click"/>
                            </Grid>
                            <TextBlock x:Name="BackupStatusText" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <!-- API使用量 -->
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="10,8" Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="API使用量(%)" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="QuotaBarBg" Grid.Column="0"
                                                Background="{DynamicResource SurfaceElevatedBrush}"
                                                CornerRadius="4" Height="10"
                                                VerticalAlignment="Center">
                                            <Grid HorizontalAlignment="Left">
                                                <Border x:Name="QuotaBar"
                                                        CornerRadius="4" Height="10" Width="0"
                                                        MinWidth="0"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock x:Name="QuotaPercentText" Grid.Column="1"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                    </Grid>
                                    <TextBlock x:Name="QuotaInfoText" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="本日の実使用量(%)" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,10,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ActualQuotaBarBg" Grid.Column="0"
                                                Background="{DynamicResource SurfaceElevatedBrush}"
                                                CornerRadius="4" Height="10"
                                                VerticalAlignment="Center">
                                            <Grid HorizontalAlignment="Left">
                                                <Border x:Name="ActualQuotaBar"
                                                        CornerRadius="4" Height="10" Width="0"
                                                        MinWidth="0"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock x:Name="ActualQuotaPercentText" Grid.Column="1"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TextMutedBrush}"/>
                                    </Grid>
                                    <TextBlock x:Name="ActualQuotaInfoText" FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 表示 -->
                    <ScrollViewer x:Name="SettingsPageDisplay" Style="{StaticResource SlimScrollViewer}" Visibility="Visible"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <!-- 表示グループ -->
                            <TextBlock Text="表示" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="2,0,0,6"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Background="{DynamicResource SurfaceAltBrush}"
                                    Padding="12,4">
                                <StackPanel>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ダークモード" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="DarkModeToggle" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="DarkModeToggle_Changed"
                                                  Unchecked="DarkModeToggle_Changed"/>
                                    </Grid>
                                    <Separator Style="{StaticResource HorizontalSeparator}"/>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="カテゴリなし表示" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="NoCategoryModeToggle" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="NoCategoryModeToggle_Changed"
                                                  Unchecked="NoCategoryModeToggle_Changed"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ログフィルタグループ -->
                            <TextBlock Text="ログフィルタ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="2,16,0,6"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Background="{DynamicResource SurfaceAltBrush}"
                                    Padding="12,4">
                                <StackPanel>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ログレベル" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="LogLevelComboBox" Grid.Column="1"
                                                  Style="{StaticResource ModernComboBox}"
                                                  SelectionChanged="LogLevelComboBox_Changed">
                                            <ComboBoxItem Content="情報"  Tag="Info"    Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="警告"  Tag="Warning" Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="エラー" Tag="Error"   Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="DEBUG" Tag="Debug"   Style="{StaticResource ModernComboBoxItem}"/>
                                        </ComboBox>
                                    </Grid>
                                    <Separator Style="{StaticResource HorizontalSeparator}"/>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="自動ログ削除" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="AutoCleanLogsToggle" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="AutoCleanLogsToggle_Changed"
                                                  Unchecked="AutoCleanLogsToggle_Changed"/>
                                    </Grid>
                                    <Separator Style="{StaticResource HorizontalSeparator}"/>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ログ保持期間" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <ComboBox x:Name="LogRetentionComboBox" Grid.Column="1"
                                                  Style="{StaticResource ModernComboBox}"
                                                  SelectionChanged="LogRetentionComboBox_Changed">
                                            <ComboBoxItem Content="0日（当日のみ）" Tag="0"  Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="1日"  Tag="1"   Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="3日"  Tag="3"   Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="5日"  Tag="5"   Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="7日"  Tag="7"   Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="無制限" Tag="-1" Style="{StaticResource ModernComboBoxItem}"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ログ操作（グループ外） -->
                            <TextBlock x:Name="LogCleanResultText" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,12,0,6" Text=""/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Content="🗑 削除実行" Padding="14,7"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Click="CleanLogsNow_Click"/>
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                        Content="📋 ログを表示" Padding="14,7"
                                        VerticalAlignment="Center"
                                        Click="ShowActivityLog_Click"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="12,10">
                                <TextBlock x:Name="LogStatsText"
                                           Text="ログ情報を読み込み中..."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ログフィルタ（空ページ・ナビ互換のため残す） -->
                    <ScrollViewer x:Name="SettingsPageLog" Style="{StaticResource SlimScrollViewer}" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel/>
                    </ScrollViewer>

                    <!-- ABOUT -->
                    <ScrollViewer x:Name="SettingsPageAbout" Style="{StaticResource SlimScrollViewer}" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <TextBlock Text="YTNotifier" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="v0.8.1" FontSize="13"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,0,12"/>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <TextBlock Text="YouTube新着動画通知アプリ" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="YouTube Data API v3 使用" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <TextBlock Text="Created by Coco" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,0"/>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Button x:Name="OpenDebugWindowBtn"
                                    Content="🛠 開発者ツールを開く"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="12,6" FontSize="11"
                                    HorizontalAlignment="Left"
                                    Visibility="Collapsed"
                                    Click="OpenDebugWindow_Click"/>
                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Grid>

        </Grid>
        </Grid><!-- メインレイアウト -->

    </Grid><!-- ルートGrid -->
    </Border><!-- ウィンドウ外枠 -->
</Window>
