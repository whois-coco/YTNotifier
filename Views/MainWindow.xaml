                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="FlashTaskbarToggle_Changed"
                                                  Unchecked="FlashTaskbarToggle_Changed"/>
                                    </Grid>
                                    <Separator Style="{StaticResource HorizontalSeparator}"/>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="デスクトップ通知" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="NotificationToggle" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="NotificationToggle_Changed"
                                                  Unchecked="NotificationToggle_Changed"/>
                                    </Grid>
                                    <Separator Style="{StaticResource HorizontalSeparator}"/>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="通知スタイル" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
