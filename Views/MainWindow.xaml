                                                  Style="{StaticResource ModernComboBox}"
                                                  SelectionChanged="IntervalComboBox_SelectionChanged">
                                            <ComboBoxItem Content="3分"  Tag="3"  Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="5分"  Tag="5"  Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="10分" Tag="10" Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="15分" Tag="15" Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="20分" Tag="20" Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="30分" Tag="30" Style="{StaticResource ModernComboBoxItem}"/>
                                            <ComboBoxItem Content="60分" Tag="60" Style="{StaticResource ModernComboBoxItem}"/>
                                        </ComboBox>
                                    </Grid>
                                    <Separator Style="{StaticResource HorizontalSeparator}"/>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="プレミア/ライブ待機所通知" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
