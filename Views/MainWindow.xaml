                                                <Path Data="m21 21-4.35-4.35"
                                                      Stroke="{DynamicResource TextMutedBrush}"
                                                      StrokeThickness="2" StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" Fill="Transparent"/>
