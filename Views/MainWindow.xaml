                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                    <Path Data="M21 3v5h-5"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                    <Path Data="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                    <Path Data="M8 16H3v5"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Fill="Transparent"/>
