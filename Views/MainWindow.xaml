                                        <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                              StrokeThickness="2" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" Fill="Transparent" Data="M12 11h4"/>
                                        <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                              StrokeThickness="2" StrokeStartLineCap="Round"
