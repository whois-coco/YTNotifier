                        </Viewbox>
                        <TextBlock Text="設定" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- サブナビゲーション（横向き） -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Height="36">
                        <Border x:Name="SettingsNavDisplay"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryBrush}"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="表示" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SettingsNavMonitor"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="通知" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SettingsNavApp"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="動作" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="SettingsNavAbout"
                                Padding="16,0" Cursor="Hand"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                MouseLeftButtonUp="SettingsNavBorder_Click">
                            <TextBlock Text="ABOUT" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- コンテンツエリア -->
                <Grid Grid.Row="2">

                    <!-- API -->
<!-- 監視 -->
                    <ScrollViewer x:Name="SettingsPageMonitor" Style="{StaticResource SlimScrollViewer}" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto" Margin="20,16">
                        <StackPanel>
                            <!-- 通知グループ -->
                            <TextBlock Text="通知" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="2,0,0,6"/>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Background="{DynamicResource SurfaceAltBrush}"
                                    Padding="12,4">
                                <StackPanel>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="チェック間隔" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
