                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="GlobalNotifyUpcomingToggle_Changed"
                                                  Unchecked="GlobalNotifyUpcomingToggle_Changed"/>
                                    </Grid>
                                    <Separator Style="{StaticResource HorizontalSeparator}"/>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="通知音" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox x:Name="NotificationSoundToggle" Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Checked="NotificationSoundToggle_Changed"
                                                  Unchecked="NotificationSoundToggle_Changed"/>
                                    </Grid>
                                    <Separator Style="{StaticResource HorizontalSeparator}"/>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="タスクバー点滅" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
