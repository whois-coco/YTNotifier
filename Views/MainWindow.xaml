<Window x:Class="YTNotifier.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="YTNotifier" Height="740" Width="980"
        MinHeight="580" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- サイドバーナビボタン -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="Foreground"                Value="{DynamicResource SidebarTextBrush}"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="Padding"                   Value="16,10"/>
            <Setter Property="FontSize"                  Value="13"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="Icon"
                                           Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="14" Width="22"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           Foreground="{DynamicResource SidebarTextBrush}"/>
                                <ContentPresenter x:Name="Content" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SidebarHoverBrush}"/>
                                <Setter TargetName="Icon" Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アクティブナビ: 左に青ライン -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{DynamicResource SidebarHoverBrush}"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                               FontSize="14" Width="22"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"
                                               Foreground="{DynamicResource SidebarActiveTextBrush}"/>
                                    <ContentPresenter VerticalAlignment="Center"
                                                      TextBlock.Foreground="{DynamicResource SidebarActiveTextBrush}"/>
                                </StackPanel>
                            </Border>
                            <!-- アクティブインジケーター -->
                            <Border Width="3" HorizontalAlignment="Left"
                                    Background="{DynamicResource SidebarActiveBrush}"
                                    CornerRadius="0,2,2,0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ウィンドウ外枠（フラット枠線） -->
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== カスタムタイトルバー ===== -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- アプリ名 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0">
                    <Border Width="20" Height="20" CornerRadius="3"
                            Background="{DynamicResource AccentBrush}"
                            Margin="0,0,8,0">
                        <TextBlock Text="▶" Foreground="White" FontSize="9"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="YTNotifier" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource SidebarTitleBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ドラッグ領域 -->
                <Border Grid.Column="1"/>

                <!-- ウィンドウ操作ボタン -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 最小化 -->
                    <Button Click="TitleBar_Minimize"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="最小化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock Text="─" Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 最大化/復元 -->
                    <Button x:Name="MaximizeButton" Click="TitleBar_Maximize"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="最大化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock x:Name="MaxIcon" Text="□"
                                               Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 閉じる -->
                    <Button Click="TitleBar_Close"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="閉じる">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock Text="✕" Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="#EF4444"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== メインレイアウト（タイトルバー下） ===== -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== サイドバー ===== -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <DockPanel>

                <!-- ステータス -->
                <Border DockPanel.Dock="Top"
                        Padding="16,12,16,12"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Border Background="{DynamicResource SidebarStatusBgBrush}" CornerRadius="3"
                            Padding="8,5" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush x:Name="StatusDot" Color="#94A3B8"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="StatusText" Text="停止中"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#94A3B8"/>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ナビゲーション -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <TextBlock Text="MENU" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource SidebarSectionBrush}"
                               Margin="16,0,0,6"/>
                    <Button x:Name="NavWatch" Tag="📋" Content="監視リスト"
                            Style="{StaticResource NavButtonActive}"
                            Click="Nav_Click"/>
                    <Button x:Name="NavLog" Tag="📝" Content="動作ログ"
                            Style="{StaticResource NavButton}"
                            Click="Nav_Click"/>
                    <Button x:Name="NavSettings" Tag="⚙" Content="基本設定"
                            Style="{StaticResource NavButton}"
                            Click="Nav_Click"/>
                </StackPanel>

                <!-- 区切り -->
                <Border DockPanel.Dock="Top" Height="1"
                        Background="{DynamicResource SidebarBorderBrush}" Margin="0,8"/>

                <!-- アクション -->
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="ACTIONS" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource SidebarSectionBrush}"
                               Margin="16,0,0,6"/>
                    <Button Tag="🔄" Content="今すぐチェック"
                            Style="{StaticResource NavButton}"
                            x:Name="ManualCheckButton"
                            Click="ManualCheckButton_Click"/>
                    <Button x:Name="MonitorToggleButton" Tag="▶" Content="監視開始"
                            Style="{StaticResource NavButton}"
                            Click="MonitorToggleButton_Click"/>
                </StackPanel>

                <!-- バージョン -->
                <Border DockPanel.Dock="Bottom" Padding="16,12"
                        BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,1,0,0">
                    <TextBlock Text="v1.0.0" FontSize="11" Foreground="{DynamicResource SidebarVersionBrush}"/>
                </Border>

            </DockPanel>
        </Border>

        <!-- ===== メインコンテンツ ===== -->
        <Grid Grid.Column="1" Background="{DynamicResource BackgroundBrush}">

            <!-- 監視リスト -->
            <DockPanel x:Name="PageWatch" Margin="24,20">

                <!-- ページヘッダー -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="監視リスト" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="ChannelCountText" Text="0 チャンネル"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- チャンネル追加（折り畳み） -->
                <Border DockPanel.Dock="Bottom"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <StackPanel>
                        <!-- ヘッダー -->
                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Style="{StaticResource IconButton}"
                                Padding="16,12"
                                Click="AddChannelHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="チャンネルを追加" FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="AddChannelChevron" Grid.Column="1"
                                           Text="▼" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- コンテンツ -->
                        <Border x:Name="AddChannelBody"
                                Visibility="Collapsed"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="チャンネルID / ハンドル / URL"
                                               Style="{StaticResource FieldLabel}"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" Margin="0,0,8,0">
                                            <TextBox x:Name="ChannelInputBox"
                                                     Style="{StaticResource ModernTextBox}"
                                                     KeyDown="ChannelInputBox_KeyDown"
                                                     TextChanged="ChannelInputBox_TextChanged"/>
                                            <TextBlock x:Name="ChannelInputPlaceholder"
                                                       Text="@handle / UCxxxxxxx / URL..."
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="13" Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"/>
                                        </Grid>
                                        <Button Grid.Column="1" x:Name="PreviewButton"
                                                Style="{StaticResource SecondaryButton}"
                                                Content="検索" Padding="14,8"
                                                Click="PreviewChannel_Click"/>
                                    </Grid>
                                    <TextBlock x:Name="PreviewStatusText" FontSize="12"
                                               Margin="0,0,0,10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Text="チャンネルIDまたはハンドル名を入力してください"
                                               TextWrapping="Wrap"/>
                                    <Button x:Name="AddChannelButton"
                                            Style="{StaticResource PrimaryButton}"
                                            Content="追加する" Padding="16,8"
                                            HorizontalAlignment="Left"
                                            IsEnabled="False" Click="AddChannel_Click"/>
                                </StackPanel>

                                <!-- プレビュー -->
                                <Border Grid.Column="1"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4" Padding="14">
                                    <StackPanel>
                                        <TextBlock Text="PREVIEW"
                                                   Style="{StaticResource SectionHeader}"/>
                                        <Border x:Name="PreviewEmptyState">
                                            <StackPanel HorizontalAlignment="Center"
                                                        Margin="0,10,0,0">
                                                <TextBlock Text="🔍" FontSize="24"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="ここに表示" FontSize="12"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <StackPanel x:Name="PreviewContent" Visibility="Collapsed">
                                            <Border Width="44" Height="44" CornerRadius="22"
                                                    HorizontalAlignment="Center" Margin="0,4,0,8">
                                                <Border.Clip>
                                                    <EllipseGeometry Center="22,22"
                                                                     RadiusX="22" RadiusY="22"/>
                                                </Border.Clip>
                                                <Image x:Name="PreviewThumbnail"
                                                       Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock x:Name="PreviewName" FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="PreviewHandle" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextAlignment="Center" Margin="0,2,0,6"/>
                                            <Border Background="{DynamicResource PrimaryLightBrush}"
                                                    BorderBrush="{DynamicResource PrimaryBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="3" Padding="8,3"
                                                    HorizontalAlignment="Center">
                                                <TextBlock x:Name="PreviewSubs" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Height="12"/>

                <!-- チャンネルリスト -->
                <Grid>
                    <Border x:Name="EmptyState" Visibility="Collapsed" Panel.ZIndex="1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="0,40,0,0">
                            <TextBlock Text="📭" FontSize="40"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="監視チャンネルがありません"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="下のフォームからチャンネルを追加してください"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="ChannelScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalContentAlignment="Stretch">
                        <ScrollViewer.Template>
                            <ControlTemplate TargetType="ScrollViewer">
                                <Grid HorizontalAlignment="Stretch">
                                    <ScrollContentPresenter
                                        HorizontalAlignment="Stretch"
                                        CanContentScroll="False"/>
                                    <ScrollBar x:Name="PART_VerticalScrollBar"
                                               HorizontalAlignment="Right"
                                               Width="4"
                                               Value="{TemplateBinding VerticalOffset}"
                                               Maximum="{TemplateBinding ScrollableHeight}"
                                               ViewportSize="{TemplateBinding ViewportHeight}"
                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                               Style="{StaticResource SlimScrollBar}"/>
                                </Grid>
                            </ControlTemplate>
                        </ScrollViewer.Template>
                        <StackPanel x:Name="ChannelList" HorizontalAlignment="Stretch"/>
                    </ScrollViewer>
                </Grid>
            </DockPanel>

            <!-- 動作ログ -->
            <DockPanel x:Name="PageLog" Visibility="Collapsed" Margin="24,20">
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0,0,0,16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="動作ログ" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="リアルタイム監視ログ" FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="フォルダを開く" Padding="12,7"
                                    Margin="0,0,8,0" Click="OpenLogFolder_Click"/>
                            <Button Style="{StaticResource IconButton}"
                                    Click="ClearLog_Click" ToolTip="クリア" Padding="8">
                                <TextBlock Text="🗑" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="0">
                    <Border Background="{DynamicResource LogBackgroundBrush}"
                            CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                            <ItemsControl x:Name="LogList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58"/>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FormattedTime, Mode=OneWay}"
                                                       FontFamily="Cascadia Code, Consolas"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" CornerRadius="2"
                                                    Padding="5,1" Margin="0,0,6,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding LevelColor, Mode=OneWay}"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding LevelText, Mode=OneWay}"
                                                           FontSize="9" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <TextBlock FontFamily="Cascadia Code, Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           Text="{Binding ChannelName, Mode=OneWay, StringFormat='[{0}] '}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock FontFamily="Cascadia Code, Consolas"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource LogTextBrush}"
                                                           Text="{Binding Message, Mode=OneWay}"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Border>
            </DockPanel>

            <!-- 基本設定 -->
            <ScrollViewer x:Name="PageSettings" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Margin="24,20">
                <StackPanel>
                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,16" Margin="0,0,0,20">
                        <TextBlock Text="基本設定" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>

                    <!-- API設定 -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="API KEY" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="YouTube Data API v3" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="APIキー" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ApiKeyBox" Grid.Column="0"
                                         Style="{StaticResource ModernTextBox}"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                        Content="保存" Padding="16,8"
                                        Click="SaveApiKey_Click"/>
                            </Grid>
                            <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}">
                                <Hyperlink RequestNavigate="ApiKeyLink_Click"
                                           NavigateUri="https://console.developers.google.com">
                                    Google Cloud Console でAPIキーを取得 →
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 監視設定 -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="MONITORING" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="監視設定" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="チェック間隔" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="新着動画をチェックする間隔" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox x:Name="IntervalComboBox" Grid.Column="1"
                                          Style="{StaticResource ModernComboBox}"
                                          SelectionChanged="IntervalComboBox_SelectionChanged">
                                    <ComboBoxItem Content="1分"       Tag="1"  Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="5分（推奨）" Tag="5"  Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="10分"      Tag="10" Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="30分"      Tag="30" Style="{StaticResource ModernComboBoxItem}"/>
                                    <ComboBoxItem Content="60分"      Tag="60" Style="{StaticResource ModernComboBoxItem}"/>
                                </ComboBox>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="デスクトップ通知" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Windowsトースト通知で新着を表示" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="NotificationToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="NotificationToggle_Changed"
                                          Unchecked="NotificationToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="通知テスト" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="テスト通知を送信して動作確認" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                        Content="🔔 送信" Padding="14,7"
                                        VerticalAlignment="Center"
                                        Click="TestNotification_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- アプリ設定 -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="APPLICATION" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="アプリ設定" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="ダークモード" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="アプリのテーマを切り替え" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="DarkModeToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="DarkModeToggle_Changed"
                                          Unchecked="DarkModeToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="タスクトレイに格納" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="×ボタンでトレイに常駐" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="TrayToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="TrayToggle_Changed"
                                          Unchecked="TrayToggle_Changed"/>
                            </Grid>
                            <Separator Style="{StaticResource HorizontalSeparator}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="スタートアップ起動" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Windows起動時に自動起動" FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="StartupToggle" Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          VerticalAlignment="Center"
                                          Checked="StartupToggle_Changed"
                                          Unchecked="StartupToggle_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
        </Grid><!-- メインレイアウト -->
    </Grid><!-- ルートGrid -->
    </Border><!-- ウィンドウ外枠 -->
</Window>
