<Window x:Class="YTNotifier.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="YTNotifier" Height="740" Width="980"
        MinHeight="500" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- サイドバーナビボタン -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="Padding"                Value="0"/>
            <Setter Property="Height"                 Value="40"/>
            <Setter Property="HorizontalAlignment"    Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="NavIcon"
                                           Grid.Column="0"
                                           Text="{Binding Tag,
                                               RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SidebarTextBrush}"/>
                                <TextBlock x:Name="NavLabel"
                                           Grid.Column="1"
                                           Text="{TemplateBinding Content}"
                                           FontSize="13"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SidebarTextBrush}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SidebarHoverBrush}"/>
                                <Setter TargetName="NavIcon" Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter TargetName="NavLabel" Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Content" Value="">
                                <Setter TargetName="NavLabel" Property="Visibility"
                                        Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アクティブナビ: 左に青ライン（BasedOn は使用しない。Template を完全置換するため） -->
        <Style x:Key="NavButtonActive" TargetType="Button">
            <Setter Property="Background"          Value="{DynamicResource SidebarHoverBrush}"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="Height"              Value="40"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid ClipToBounds="True">
                            <Border Background="{DynamicResource SidebarHoverBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="NavIcon"
                                               Grid.Column="0"
                                               Text="{Binding Tag,
                                                   RelativeSource={RelativeSource TemplatedParent}}"
                                               FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SidebarActiveTextBrush}"/>
                                    <TextBlock x:Name="NavLabel"
                                               Grid.Column="1"
                                               Text="{TemplateBinding Content}"
                                               FontSize="13"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource SidebarActiveTextBrush}"/>
                                </Grid>
                            </Border>
                            <Border Width="3" HorizontalAlignment="Left"
                                    Background="{DynamicResource SidebarActiveBrush}"
                                    CornerRadius="0,2,2,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="">
                                <Setter TargetName="NavLabel" Property="Visibility"
                                        Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ウィンドウ外枠（フラット枠線） -->
    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== カスタムタイトルバー ===== -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- アプリ名（サイドバー幅に追従・クリップ） -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0"
                            ClipToBounds="True">
                    <Border Width="20" Height="20" CornerRadius="3"
                            Background="{DynamicResource AccentBrush}"
                            Margin="0,0,8,0">
                        <TextBlock Text="▶" Foreground="White" FontSize="9"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TitleText" Text="YTNotifier" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource SidebarTitleBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- ドラッグ領域 -->
                <Border Grid.Column="1"/>

                <!-- ウィンドウ操作ボタン -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 最小化 -->
                    <Button Click="TitleBar_Minimize"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="最小化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock Text="─" Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 最大化/復元 -->
                    <Button x:Name="MaximizeButton" Click="TitleBar_Maximize"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="最大化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock x:Name="MaxIcon" Text="□"
                                               Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- 閉じる -->
                    <Button Click="TitleBar_Close"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" ToolTip="閉じる">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        Width="46" Height="40">
                                    <TextBlock x:Name="CloseIcon" Text="✕"
                                               Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ErrorBrush}"/>
                                        <Setter TargetName="CloseIcon" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== メインレイアウト（タイトルバー下） ===== -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="110" MinWidth="0"/>
            <ColumnDefinition x:Name="ContentColumn" Width="360" MinWidth="360"/>
        </Grid.ColumnDefinitions>

        <!-- ===== サイドバー ===== -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}"
                ClipToBounds="True">
            <DockPanel>

                <!-- ステータス＋折り畳みボタン -->
                <Border DockPanel.Dock="Top"
                        Height="48"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="StatusBadgeColumn" Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- ステータスバッジ（クリックで監視トグル） -->
                        <Button x:Name="StatusBadge"
                                Grid.Column="0"
                                Background="{DynamicResource SidebarStatusBgBrush}"
                                BorderThickness="0"
                                Padding="6,4"
                                Margin="0"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Cursor="Hand"
                                ToolTip="クリックして監視を開始/停止"
                                Click="MonitorToggleButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="3"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- 監視中アイコン (Eye) -->
                                            <Viewbox x:Name="IconRunning" Width="20" Height="20"
                                                     VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"
                                                          Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                                                    <Path Data="M 9 12 A 3 3 0 0 0 15 12 A 3 3 0 0 0 9 12"
                                                          Stroke="{DynamicResource SuccessBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                </Canvas>
                                            </Viewbox>
                                            <!-- 停止中アイコン (EyeClosed) -->
                                            <Viewbox x:Name="IconStopped" Width="20" Height="20"
                                                     VerticalAlignment="Center"
                                                     Visibility="Collapsed">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="m15 18-.722-3.25"
                                                          Stroke="{DynamicResource SidebarTextBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="M2 8a10.645 10.645 0 0 0 20 0"
                                                          Stroke="{DynamicResource SidebarTextBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="m20 15-1.726-2.05"
                                                          Stroke="{DynamicResource SidebarTextBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="m4 15 1.726-2.05"
                                                          Stroke="{DynamicResource SidebarTextBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="m9 18 .722-3.25"
                                                          Stroke="{DynamicResource SidebarTextBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                </Canvas>
                                            </Viewbox>
                                            <!-- オフラインアイコン (WifiOff) -->
                                            <Viewbox x:Name="IconOffline" Width="20" Height="20"
                                                     VerticalAlignment="Center"
                                                     Visibility="Collapsed">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M2 2l20 20"
                                                          Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="M8.5 16.5a5 5 0 0 1 7 0"
                                                          Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="M2 8.82a15 15 0 0 1 4.17-2.65"
                                                          Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="M10.66 5c4.01-.36 8.14.9 11.34 3.76"
                                                          Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="M16.85 11.25a10 10 0 0 1 2.22 1.68"
                                                          Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="M5 12.85a10 10 0 0 1 5.17-2.39"
                                                          Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    <Path Data="M12 20h.01"
                                                          Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="StatusText"
                                                       Text="停止中"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SidebarTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="6,0,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- コンパクトモード + ピンボタン（サイドバー左下） -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource SidebarBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Button x:Name="SidebarToggleButton"
                                Height="44"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                ToolTip="折り畳む"
                                Click="SidebarToggle_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" Height="44" Padding="10,0,10,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="24" Height="24" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path x:Name="CollapseIcon"
                                                          Stroke="{DynamicResource SidebarTextBrush}"
                                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Data="m11 17-5-5 5-5 M18 17l-5-5 5-5"/>
                                                    <Path x:Name="ExpandToggleIcon"
                                                          Stroke="{DynamicResource SidebarTextBrush}"
                                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Visibility="Collapsed"
                                                          Data="m6 17 5-5-5-5 M13 17l5-5-5-5"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="LblSidebarToggleButton" Text="折り畳む" FontSize="12"
                                                       Foreground="{DynamicResource SidebarTextBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border Height="1" Background="{DynamicResource SidebarBorderBrush}" Margin="8,0"/>
                        <Button x:Name="NavSettings"
                                Height="44"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                ToolTip="設定"
                                Click="Nav_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid x:Name="Bd" Height="44">
                                        <Border x:Name="BdBg" Background="Transparent"/>
                                        <Border x:Name="SelectorBar" Width="3" HorizontalAlignment="Left"
                                                Background="Transparent" CornerRadius="0,2,2,0"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0">
                                            <Viewbox Width="24" Height="24" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                <Path Stroke="{DynamicResource SidebarTextBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915"/>
                                                <Path Stroke="{DynamicResource SidebarTextBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent" Data="M 9 12 A 3 3 0 0 0 15 12 A 3 3 0 0 0 9 12"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="LblNavSettings" Text="設定" FontSize="12"
                                                       Foreground="{DynamicResource SidebarTextBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BdBg" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Border Height="1" Background="{DynamicResource SidebarBorderBrush}" Margin="8,0"/>
                        <Button x:Name="MuteButton"
                                Height="44"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                ToolTip="通知ミュート: OFF"
                                Click="MuteButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" Height="44" Padding="10,0,10,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="24" Height="24" VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <!-- OFF時: bell アイコン -->
                                                    <Path x:Name="BellIcon"
                                                          Stroke="{DynamicResource SidebarTextBrush}"
                                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Data="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                                                    <Path x:Name="BellIcon2"
                                                          Stroke="{DynamicResource SidebarTextBrush}"
                                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Fill="Transparent"
                                                          Data="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
                                                    <!-- ON時: bell-off アイコン（赤） -->
                                                    <Path x:Name="BellOffIcon"
                                                          Stroke="{DynamicResource ErrorBrush}"
                                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Visibility="Collapsed"
                                                          Data="M8.7 3A6 6 0 0 1 18 8a21.3 21.3 0 0 0 .6 5"/>
                                                    <Path x:Name="BellOffIcon2"
                                                          Stroke="{DynamicResource ErrorBrush}"
                                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Visibility="Collapsed"
                                                          Data="M17 17H3s3-2 3-9a4.67 4.67 0 0 1 .3-1.7"/>
                                                    <Path x:Name="BellOffIcon3"
                                                          Stroke="{DynamicResource ErrorBrush}"
                                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Fill="Transparent"
                                                          Visibility="Collapsed"
                                                          Data="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
                                                    <Path x:Name="BellOffIcon4"
                                                          Stroke="{DynamicResource ErrorBrush}"
                                                          StrokeThickness="2" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Fill="Transparent"
                                                          Visibility="Collapsed"
                                                          Data="m2 2 20 20"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="LblMuteButton" Text="通知ミュート" FontSize="12"
                                                       Foreground="{DynamicResource SidebarTextBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="CompactModeButton"
                                Height="44"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalAlignment="Left"
                                ToolTip="コンパクトモード: OFF"
                                Click="CompactModeButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" Height="44" Padding="10,0,10,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="24" Height="24" VerticalAlignment="Center">
                                                <Canvas x:Name="CompactIconCanvas" Width="24" Height="24">
                                                <Path x:Name="ExpandIcon" Stroke="{DynamicResource SidebarTextBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Data="M15 15 L21 21 M15 9 L21 3 M21 16 L21 21 L16 21 M21 8 L21 3 L16 3 M3 16 L3 21 L8 21 M3 21 L9 15 M3 8 L3 3 L8 3 M9 9 L3 3"/>
                                                <Path x:Name="ShrinkIcon" Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" Visibility="Collapsed" Data="M15 15 L21 21 M15 15 L15 19.8 M15 15 L19.8 15 M9 19.8 L9 15 M9 15 L4.2 15 M9 15 L3 21 M15 4.2 L15 9 M15 9 L19.8 9 M15 9 L21 3 M9 4.2 L9 9 M9 9 L4.2 9 M9 9 L3 3"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="LblCompactModeButton" Text="コンパクト" FontSize="12"
                                                       Foreground="{DynamicResource SidebarTextBrush}"
                                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
