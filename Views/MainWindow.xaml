                                         HorizontalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M2 2l20 20"
                                              Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M8.5 16.5a5 5 0 0 1 7 0"
                                              Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M2 8.82a15 15 0 0 1 4.17-2.65"
                                              Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M10.66 5c4.01-.36 8.14.9 11.34 3.76"
                                              Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M16.85 11.25a10 10 0 0 1 2.22 1.68"
                                              Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M5 12.85a10 10 0 0 1 5.17-2.39"
                                              Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M12 20h.01"
                                              Stroke="{DynamicResource ErrorBrush}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="インターネット接続がありません。"
                                           FontSize="12" TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel x:Name="ChannelList" HorizontalAlignment="Stretch"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </DockPanel>

            <!-- 設定 -->
            <Grid x:Name="PageSettings" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ページタイトル -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="24,20,24,16">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="{DynamicResource TextPrimaryBrush}"
                                      StrokeThickness="2" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Fill="Transparent"
