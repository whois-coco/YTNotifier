<Window x:Class="YTNotifier.Views.ChannelDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Width="380" MinWidth="380" MaxWidth="380"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border CornerRadius="8" BorderThickness="1">
        <Border.Background><DynamicResource ResourceKey="SurfaceBrush"/></Border.Background>
        <Border.BorderBrush><DynamicResource ResourceKey="BorderBrush"/></Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="4" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Border Grid.Row="0" CornerRadius="8,8,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Border.Background><DynamicResource ResourceKey="SidebarBrush"/></Border.Background>
                <Grid Margin="16,0,12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="詳細設定" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="28" Height="28" Content="✕"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="CloseButton_Click"
                            FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                </Grid>
            </Border>

            <!-- コンテンツ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource SlimScrollViewer}">
                <StackPanel Margin="20,16,20,4">

                    <!-- チャンネル名 -->
                    <TextBlock x:Name="ChannelNameText" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>

                    <!-- カテゴリ -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="カテゴリ：" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="CategoryText" Grid.Column="1"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 通知種別 -->
                    <TextBlock Text="通知種別" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- 動画 -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Orientation="Horizontal">
                            <ToggleButton x:Name="NotifyVideoToggle" Style="{StaticResource KindToggleVideo}"
                                          Width="40" ToolTip="動画" Margin="0,0,6,0">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M16 13 L21.223 16.482 A0.5 0.5 0 0 0 22 16.066 L22 7.87 A0.5 0.5 0 0 0 21.248 7.438 L16 10.5 Z"
                                              Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                                        <Path Data="M2 6 L16 6 C17.105 6 18 6.895 18 8 L18 18 C18 19.105 17.105 20 16 20 L2 20 C0.895 20 0 19.105 0 18 L0 8 C0 6.895 0.895 6 2 6 Z"
                                              Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>
                            <TextBlock Text="動画" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <!-- Short -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Orientation="Horizontal">
                            <ToggleButton x:Name="NotifyShortToggle" Style="{StaticResource KindToggleShort}"
                                          Width="40" ToolTip="Short" Margin="0,0,6,0">
                                <Viewbox Width="14" Height="14">
                                    <Path Data="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"
                                          Stretch="Uniform"
                                          Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                                </Viewbox>
                            </ToggleButton>
                            <TextBlock Text="Short" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <!-- ライブ -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Orientation="Horizontal">
                            <ToggleButton x:Name="NotifyLiveToggle" Style="{StaticResource KindToggleLive}"
                                          Width="40" ToolTip="ライブ配信" Margin="0,0,6,0">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4.9 16.1C1 12.2 1 5.8 4.9 1.9" Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M7.8 4.7a6.14 6.14 0 0 0-.8 7.5" Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M16.2 4.8c2 2 2.26 5.11.8 7.47" Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M19.1 1.9a9.96 9.96 0 0 1 0 14.1" Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="M9.5 18h5" Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Path Data="m8 22 4-11 4 11" Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent"/>
                                        <Ellipse Canvas.Left="10" Canvas.Top="7" Width="4" Height="4" Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}" StrokeThickness="2" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                            </ToggleButton>
                            <TextBlock Text="ライブ配信" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- 待機所通知オプション -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="プレミア/ライブ待機所通知"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <CheckBox x:Name="NotifyUpcomingToggle"
                                      Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 監視モード -->
                    <Separator Style="{StaticResource HorizontalSeparator}" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="監視モード" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox x:Name="MonitorModeCombo" Grid.Column="1"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="MonitorModeCombo_Changed">
                            <ComboBoxItem Content="通常" Tag="Normal" Style="{StaticResource ModernComboBoxItem}"/>
                            <ComboBoxItem Content="低頻度" Tag="LowFreq" Style="{StaticResource ModernComboBoxItem}"/>
                            <ComboBoxItem Content="時間指定" Tag="Focus" Style="{StaticResource ModernComboBoxItem}"/>
                        </ComboBox>
                    </Grid>

                    <!-- 通常モード設定 -->
                    <Border x:Name="NormalPanel" Visibility="Collapsed"
                            Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="6" Padding="14,12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="監視間隔" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="NormalIntervalBox" Width="130" Grid.Column="1"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectionChanged="ComboBox_Changed"/>
                        </Grid>
                    </Border>

                    <!-- 低頻度設定 -->
                    <Border x:Name="LowFreqPanel" Visibility="Collapsed"
                            Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="6" Padding="14,12" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="監視間隔" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="LowFreqIntervalBox" Width="130" Grid.Column="1"
                                      Style="{StaticResource ModernComboBox}"
                                      SelectionChanged="ComboBox_Changed">
                                <ComboBoxItem Content="1時間" Tag="60" Style="{StaticResource ModernComboBoxItem}"/>
                                <ComboBoxItem Content="3時間" Tag="180" Style="{StaticResource ModernComboBoxItem}"/>
                                <ComboBoxItem Content="6時間" Tag="360" Style="{StaticResource ModernComboBoxItem}"/>
                                <ComboBoxItem Content="12時間" Tag="720" Style="{StaticResource ModernComboBoxItem}"/>
                                <ComboBoxItem Content="24時間" Tag="1440" Style="{StaticResource ModernComboBoxItem}"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- 時間指定: タブUI -->
                    <Border x:Name="FocusSlotsPanel" Visibility="Collapsed"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Margin="0,0,0,8">
                        <StackPanel>
                            <!-- 横ナビ（設定タブと同形式） -->
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="6,6,0,0">
                                <StackPanel x:Name="FocusTabNav"
                                            Orientation="Horizontal"
                                            Height="36"/>
                            </Border>
                            <!-- コンテンツ -->
                            <StackPanel x:Name="FocusTabContent"
                                        Margin="14,12,14,12"/>
                        </StackPanel>
                    </Border>

                    <!-- API使用量 -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="12,8" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="API使用量(%)" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="DetailQuotaBarBg" Grid.Column="0"
                                        Background="{DynamicResource SurfaceElevatedBrush}"
                                        CornerRadius="4" Height="10" VerticalAlignment="Center">
                                    <Grid HorizontalAlignment="Left">
                                        <Border x:Name="DetailQuotaBar"
                                                CornerRadius="4" Height="10" Width="0" MinWidth="0"/>
                                    </Grid>
                                </Border>
                                <TextBlock x:Name="EstimateText" Grid.Column="1"
                                           FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ボタン行 -->
            <Grid Grid.Row="2" Margin="20,8,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="キャンセル"
                        Style="{StaticResource SecondaryButton}"
                        Padding="16,8" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Grid.Column="2" Content="保存"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,8" Click="Save_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
