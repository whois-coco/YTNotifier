<Window x:Class="YTNotifier.Views.ActivityLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="動作ログ" Height="500" Width="600"
        MinHeight="300" MinWidth="400" MaxWidth="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- タイトルバー -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="動作ログ" FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource SidebarTitleBrush}"
                           VerticalAlignment="Center" Margin="16,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Click="TitleBar_Minimize"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="46" Height="40">
                                    <TextBlock Text="─" Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="12" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Margin="0,4,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Click="TitleBar_Close"
                            Width="46" Height="40"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" Width="46" Height="40">
                                    <TextBlock x:Name="CloseIcon" Text="✕"
                                               Foreground="{DynamicResource SidebarTextBrush}"
                                               FontSize="11" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#EF4444"/>
                                        <Setter TargetName="CloseIcon" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- コンテンツ -->
        <Grid Grid.Row="1" Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ツールバー -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="動作ログ" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                        Click="ClearLog_Click" Padding="10,7" Margin="0,0,8,0"
                        Content="🗑 クリア"/>
                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                        Click="OpenLogFolder_Click" Padding="10,7"
                        Content="📁"
                        ToolTip="ログフォルダを開く"
                        AutomationProperties.Name="ログフォルダを開く"/>
            </Grid>

            <!-- ログ一覧 -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <ListBox x:Name="LogList"
                         Background="{DynamicResource LogBackgroundBrush}"
                         BorderThickness="0"
                         Padding="14"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Item">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding FormattedTime, Mode=OneWay}"
                                           FontFamily="Cascadia Code, Consolas"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Top"
                                           Margin="0,1,6,0"/>
                                <Border Grid.Column="1" CornerRadius="2"
                                        Padding="5,1" Margin="0,0,6,0"
                                        VerticalAlignment="Top">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding LevelColor, Mode=OneWay}"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding LevelText, Mode=OneWay}"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontFamily="Cascadia Code, Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               Text="{Binding ChannelNameFormatted, Mode=OneWay}"
                                               VerticalAlignment="Top"/>
                                    <TextBlock Grid.Column="1"
                                               FontFamily="Cascadia Code, Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource LogTextBrush}"
                                               Text="{Binding Message, Mode=OneWay}"
                                               VerticalAlignment="Top"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
    </Border>
</Window>
