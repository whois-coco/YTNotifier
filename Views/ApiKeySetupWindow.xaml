<Window x:Class="YTNotifier.Views.ApiKeySetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YTNotifier - 初回設定"
        Width="480" Height="230"
        MinWidth="480" MaxWidth="480"
        MinHeight="230" MaxHeight="230"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <DockPanel>

            <!-- タイトルバー -->
            <Border DockPanel.Dock="Top" Height="40"
                    Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Width="40" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="CloseButton_Click"
                            ToolTip="閉じる" AutomationProperties.Name="閉じる">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent">
                                    <TextBlock Text="✕" FontSize="11"
                                               Foreground="{DynamicResource SidebarTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CloseHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <Border Width="16" Height="16" CornerRadius="2"
                                Background="{DynamicResource AccentBrush}" Margin="0,0,8,0">
                            <TextBlock Text="▶" Foreground="White" FontSize="7"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="YouTube Data API v3 キーを設定" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SidebarTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- コンテンツ -->
            <StackPanel Margin="20,16,20,16">
                <TextBlock Text="APIキー" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ApiKeyBox" Grid.Column="0"
                             Style="{StaticResource ModernTextBox}"
                             Margin="0,0,8,0"
                             KeyDown="ApiKeyBox_KeyDown"/>
                    <Button Grid.Column="1" x:Name="SaveButton"
                            Style="{StaticResource PrimaryButton}"
                            Content="保存" Padding="16,8"
                            Click="SaveButton_Click"/>
                </Grid>
                <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}">
                    <Hyperlink RequestNavigate="ApiKeyLink_Click"
                               NavigateUri="https://console.developers.google.com">
                        Google Cloud Console でAPIキーを取得 →
                    </Hyperlink>
                </TextBlock>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="バックアップから復元する" FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Content="📂 復元" Padding="12,6"
                            Click="RestoreButton_Click"/>
                </Grid>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
