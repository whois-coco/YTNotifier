<Window x:Class="YTNotifier.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight" MinWidth="320" MaxWidth="480">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.3" Direction="270"/>
        </Border.Effect>
        <StackPanel>
            <!-- タイトルバー -->
            <Border x:Name="TitleBar" Height="38" CornerRadius="6,6,0,0"
                    Background="{DynamicResource SidebarBrush}"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock x:Name="TitleText" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource SidebarTextBrush}"
                           VerticalAlignment="Center" Margin="16,0"/>
            </Border>

            <!-- メッセージ -->
            <TextBlock x:Name="MessageText" FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextWrapping="Wrap" Margin="20,16,20,0"/>

            <!-- ボタン行 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="20,16,20,16">
                <Button x:Name="CancelButton" Content="キャンセル"
                        Style="{StaticResource SecondaryButton}"
                        Padding="14,7" Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button x:Name="OkButton"
                        Style="{StaticResource PrimaryButton}"
                        Padding="14,7" Click="Ok_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
