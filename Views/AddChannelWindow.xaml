<Window x:Class="YTNotifier.Views.AddChannelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="チャンネルを追加"
        Width="520" Height="215"
        MinWidth="520" MinHeight="215"
        MaxWidth="520" MaxHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        SizeToContent="Height">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <DockPanel>

            <!-- タイトルバー -->
            <Border DockPanel.Dock="Top" Height="40"
                    Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Width="40" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="CloseButton_Click"
                            ToolTip="閉じる" AutomationProperties.Name="閉じる">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent">
                                    <TextBlock Text="✕" FontSize="11"
                                               Foreground="{DynamicResource SidebarTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <Border Width="16" Height="16" CornerRadius="2"
                                Background="{DynamicResource AccentBrush}" Margin="0,0,8,0">
                            <TextBlock Text="▶" Foreground="White" FontSize="7"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="チャンネルを追加" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SidebarTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- メインコンテンツ -->
            <StackPanel Margin="12,10,12,12">

                <!-- 上段: プレビュー + 入力フォーム -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="68"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：プレビュー -->
                    <Border Grid.Column="0"
                            Width="68" Height="68"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <Grid Width="68" Height="68">
                            <StackPanel x:Name="PreviewEmptyState"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="16" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Image x:Name="PreviewThumbnail"
                                   Visibility="Collapsed" Stretch="UniformToFill"/>
                        </Grid>
                    </Border>

                    <!-- 右：入力フォーム -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="チャンネルURL / ID / ハンドル"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,4"/>
                        <Grid Grid.Row="1">
                            <TextBox x:Name="ChannelInputBox"
                                     Style="{StaticResource ModernTextBox}"
                                     Padding="10,8,44,8"
                                     KeyDown="ChannelInputBox_KeyDown"
                                     TextChanged="ChannelInputBox_TextChanged"/>
                            <TextBlock x:Name="ChannelInputPlaceholder"
                                       Text="https://youtube.com/... / @handle / UCxxxxxxx"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="13" Margin="11,0,40,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                            <Button x:Name="PasteButton"
                                    Width="34" Height="34"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,3,0" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="PasteButton_Click" ToolTip="クリップボードから貼り付け">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                                Width="34" Height="34">
                                            <Viewbox Width="17" Height="17">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
                                                          Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round" Fill="Transparent"/>
                                                    <Path Data="M15 2H9a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1z"
                                                          Stroke="{DynamicResource TextMutedBrush}" StrokeThickness="2"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round" Fill="Transparent"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource HoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- 連続追加チェックボックス -->
                        <CheckBox Grid.Row="2" x:Name="ContinuousAddCheckBox"
                                  Content="連続追加モード"
                                  FontSize="11"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,6,0,0"
                                  Style="{StaticResource ModernCheckBox}"
                                  Checked="ContinuousAddCheckBox_Changed"
                                  Unchecked="ContinuousAddCheckBox_Changed"/>

                        <!-- ステータステキスト + 検索・追加ボタン -->
                        <Grid Grid.Row="3" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PreviewStatusText" Grid.Column="0"
                                       FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" x:Name="PreviewButton"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="検索" Padding="14,6"
                                    Margin="0,0,8,0"
                                    Click="PreviewChannel_Click"/>
                            <Button Grid.Column="2" x:Name="AddChannelButton"
                                    Style="{StaticResource PrimaryButton}"
                                    Content="追加する" Padding="14,6"
                                    IsEnabled="False" Click="AddChannel_Click"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 拡張エリア: チャンネル発見時に表示 -->
                <Border x:Name="ExpandedArea" Visibility="Collapsed"
                        Margin="0,12,0,0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0" Padding="0,12,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- カテゴリ選択 -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="カテゴリ" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="CategoryComboBox"
                                          Style="{StaticResource ModernComboBox}"/>
                            </StackPanel>

                            <!-- チェック対象 -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="チェック対象" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <CheckBox x:Name="CheckVideo" Content="動画"
                                              IsChecked="True" FontSize="11"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Style="{StaticResource ModernCheckBox}"
                                              Margin="0,0,12,0"
                                              Checked="CheckKind_Changed" Unchecked="CheckKind_Changed"/>
                                    <CheckBox x:Name="CheckShort" Content="Short"
                                              IsChecked="True" FontSize="11"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Style="{StaticResource ModernCheckBox}"
                                              Margin="0,0,12,0"
                                              Checked="CheckKind_Changed" Unchecked="CheckKind_Changed"/>
                                    <CheckBox x:Name="CheckLive" Content="ライブ"
                                              IsChecked="True" FontSize="11"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Style="{StaticResource ModernCheckBox}"
                                              Checked="CheckKind_Changed" Unchecked="CheckKind_Changed"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- 詳細設定 Expander -->
                        <Expander x:Name="DetailExpander"
                                  Margin="0,12,0,0"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="詳細設定" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Expander.Header>
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Margin="0,8,0,0">
                                <DockPanel>
                                    <!-- タブナビゲーション（固定） -->
                                    <Border DockPanel.Dock="Top"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,10,12,0">
                                        <StackPanel x:Name="DetailFocusTabNav"
                                                    Orientation="Horizontal" Height="30"/>
                                    </Border>
                                    <!-- タブコンテンツ（スクロール可能） -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  MaxHeight="340"
                                                  Padding="12,10,12,12">
                                        <StackPanel x:Name="DetailFocusTabContent"/>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Border>

            </StackPanel>
        </DockPanel>
    </Border>
</Window>
