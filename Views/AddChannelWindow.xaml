<Window x:Class="YTNotifier.Views.AddChannelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="チャンネルを追加"
        Width="560" Height="300"
        MinWidth="480" MinHeight="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        Background="{DynamicResource SurfaceBrush}">

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- タイトルバー -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SidebarBrush}"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="チャンネルを追加" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource SidebarTextBrush}"
                               VerticalAlignment="Center" Margin="16,0"/>
                    <Button Grid.Column="1" Width="40" Height="40"
                            Content="✕" FontSize="12"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SidebarTextBrush}"
                            Cursor="Hand" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- コンテンツ -->
            <Grid Grid.Row="1" Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <!-- 入力フォーム -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="チャンネルID / ハンドル / URL"
                               Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <TextBox x:Name="ChannelInputBox"
                                     Style="{StaticResource ModernTextBox}"
                                     KeyDown="ChannelInputBox_KeyDown"
                                     TextChanged="ChannelInputBox_TextChanged"/>
                            <TextBlock x:Name="ChannelInputPlaceholder"
                                       Text="@handle / UCxxxxxxx / URL..."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="13" Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                        <Button Grid.Column="1" x:Name="PreviewButton"
                                Style="{StaticResource SecondaryButton}"
                                Content="検索" Padding="14,8"
                                Click="PreviewChannel_Click"/>
                    </Grid>
                    <TextBlock x:Name="PreviewStatusText" FontSize="12"
                               Margin="0,0,0,10"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Text="チャンネルIDまたはハンドル名を入力してください"
                               TextWrapping="Wrap"/>
                    <Button x:Name="AddChannelButton"
                            Style="{StaticResource PrimaryButton}"
                            Content="追加する" Padding="16,8"
                            HorizontalAlignment="Left"
                            IsEnabled="False" Click="AddChannel_Click"/>
                </StackPanel>

                <!-- プレビュー -->
                <Border Grid.Column="1"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="14">
                    <StackPanel>
                        <Border x:Name="PreviewEmptyState">
                            <StackPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                                <TextBlock Text="🔍" FontSize="24" HorizontalAlignment="Center"/>
                                <TextBlock Text="ここに表示" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <StackPanel x:Name="PreviewContent" Visibility="Collapsed">
                            <Border Width="44" Height="44" CornerRadius="22"
                                    HorizontalAlignment="Center" Margin="0,4,0,8">
                                <Border.Clip>
                                    <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22"/>
                                </Border.Clip>
                                <Image x:Name="PreviewThumbnail" Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock x:Name="PreviewName" FontSize="13" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock x:Name="PreviewHandle" FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextAlignment="Center" Margin="0,2,0,6"/>
                            <Border Background="{DynamicResource PrimaryLightBrush}"
                                    BorderBrush="{DynamicResource PrimaryBrush}"
                                    BorderThickness="1" CornerRadius="3" Padding="8,3"
                                    HorizontalAlignment="Center">
                                <TextBlock x:Name="PreviewSubs" FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
