<Window x:Class="YTNotifier.Views.AddChannelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="チャンネルを追加"
        Width="520" Height="190"
        MinWidth="520" MinHeight="190"
        MaxWidth="520" MaxHeight="190"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <DockPanel>

            <!-- タイトルバー -->
            <Border DockPanel.Dock="Top" Height="40"
                    Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Width="40" Height="40"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent">
                                    <TextBlock Text="✕" FontSize="11"
                                               Foreground="{DynamicResource SidebarTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <Border Width="16" Height="16" CornerRadius="2"
                                Background="{DynamicResource AccentBrush}" Margin="0,0,8,0">
                            <TextBlock Text="▶" Foreground="White" FontSize="7"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="チャンネルを追加" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SidebarTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- メインコンテンツ: 左プレビュー + 右入力 -->
            <Grid Margin="12,8,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="68"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左：プレビュー -->
                <Border Grid.Column="0"
                        Width="68" Height="68"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <Grid Width="68" Height="68">
                        <StackPanel x:Name="PreviewEmptyState"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="16" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <Image x:Name="PreviewThumbnail"
                               Visibility="Collapsed" Stretch="UniformToFill"
                               Width="68" Height="68"/>
                    </Grid>
                </Border>

                <!-- 右：入力フォーム -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ラベル + 入力 + 検索ボタン -->
                    <TextBlock Grid.Row="0"
                               Text="チャンネルID / ハンドル / URL"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4"/>
                    <Grid Grid.Row="1" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <TextBox x:Name="ChannelInputBox"
                                     Style="{StaticResource ModernTextBox}"
                                     KeyDown="ChannelInputBox_KeyDown"
                                     TextChanged="ChannelInputBox_TextChanged"/>
                            <TextBlock x:Name="ChannelInputPlaceholder"
                                       Text="@handle / UCxxxxxxx / URL..."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                        <Button Grid.Column="1" x:Name="PreviewButton"
                                Style="{StaticResource SecondaryButton}"
                                Content="検索" Padding="12,6"
                                Click="PreviewChannel_Click"/>
                    </Grid>

                    <!-- ステータステキスト + 追加ボタン（横並び） -->
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewStatusText" Grid.Column="0"
                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="AddChannelButton"
                                Style="{StaticResource PrimaryButton}"
                                Content="追加する" Padding="14,6"
                                HorizontalAlignment="Right"
                                IsEnabled="False" Click="AddChannel_Click"/>
                    </Grid>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>
