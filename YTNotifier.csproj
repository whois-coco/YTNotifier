<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.17763.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>YTNotifier</AssemblyName>
    <RootNamespace>YTNotifier</RootNamespace>
    <ApplicationIcon>Resources\app.ico</ApplicationIcon>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseWindowsForms>true</UseWindowsForms>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
    <!-- XAMLキャッシュを無効化 -->
    <XamlDebuggingInformation>true</XamlDebuggingInformation>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Apis.YouTube.v3" Version="1.68.0.3513" />
    <PackageReference Include="Microsoft.Toolkit.Uwp.Notifications" Version="7.1.3" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\app.ico" />
    <Resource Include="Resources\app_warn.ico" />
    <Content Include="Resources\app.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- notification.wav が存在する場合のみ出力フォルダにコピー -->
  <ItemGroup>
    <None Include="Resources\notification.wav" Condition="Exists('Resources\notification.wav')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Page Update="Views\MainWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Update="Views\AddChannelWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Update="Views\ApiKeySetupWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Update="Themes\CommonStyles.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Themes\LightTheme.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
    <Page Update="Themes\DarkTheme.xaml">
      <Generator>MSBuild:Compile</Generator>
    </Page>
  </ItemGroup>

  <!-- 発行前にobjフォルダのBAMLキャッシュを削除するターゲット -->
  <Target Name="CleanBamlCache" BeforeTargets="BeforeBuild">
    <ItemGroup>
      <BamlFiles Include="$(IntermediateOutputPath)**\*.baml" />
    </ItemGroup>
    <Delete Files="@(BamlFiles)" />
  </Target>
</Project>
